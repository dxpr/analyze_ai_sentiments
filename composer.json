{
    "name": "drupal/analyze_ai_sentiments",
    "description": "Analyzes content for sentiments and other metrics using AI.",
    "type": "drupal-module",
    "license": "GPL-2.0-or-later",
    "require": {
        "drupal/analyze": "^1.1",
        "drupal/ai": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpstan/extension-installer": "^1.3",
        "mglaman/phpstan-drupal": "^1.2",
        "phpstan/phpstan-deprecation-rules": "^1.1"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
} 