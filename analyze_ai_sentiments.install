<?php

/**
 * @file
 * Install, update and uninstall functions for the analyze_ai_sentiments module.
 */

/**
 * Implements hook_schema().
 */

/**
 * @return array<string, mixed>
 */
function analyze_ai_sentiments_schema(): array {
  $schema = [];

  $schema['analyze_ai_sentiments_results'] = [
    'description' => 'Stores AI sentiments analysis results for content entities.',
    'fields' => [
      'id' => [
        'type' => 'serial',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Primary Key: Unique analysis result ID.',
      ],
      'entity_type' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'The entity type being analyzed.',
      ],
      'entity_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'The entity ID being analyzed.',
      ],
      'entity_revision_id' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'description' => 'The entity revision ID (if applicable).',
      ],
      'langcode' => [
        'type' => 'varchar',
        'length' => 12,
        'not null' => TRUE,
        'description' => 'The language code of the analyzed content.',
      ],
      'sentiments_id' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'The sentiments metric identifier (e.g., "positivity", "engagement").',
      ],
      'score' => [
        'type' => 'numeric',
        'precision' => 3,
        'scale' => 2,
        'not null' => TRUE,
        'description' => 'The sentiments score (-1.00 to +1.00).',
      ],
      'content_hash' => [
        'type' => 'varchar',
        'length' => 64,
        'not null' => TRUE,
        'description' => 'SHA256 hash of the analyzed content.',
      ],
      'config_hash' => [
        'type' => 'varchar',
        'length' => 32,
        'not null' => TRUE,
        'description' => 'MD5 hash of the sentiments configuration.',
      ],
      'analyzed_timestamp' => [
        'type' => 'int',
        'unsigned' => TRUE,
        'not null' => TRUE,
        'description' => 'Unix timestamp when the analysis was performed.',
      ],
    ],
    'primary key' => ['id'],
    'unique keys' => [
      'entity_sentiments_lang' => ['entity_type', 'entity_id', 'sentiments_id', 'langcode'],
    ],
    'indexes' => [
      'content_hash' => ['content_hash'],
      'sentiments_id' => ['sentiments_id'],
      'analyzed_timestamp' => ['analyzed_timestamp'],
      'entity_type_bundle' => ['entity_type', 'entity_id'],
    ],
  ];

  return $schema;
}

/**
 * Implements hook_install().
 */
function analyze_ai_sentiments_install(): void {
  // Create tables from schema.
  $schema = analyze_ai_sentiments_schema();
  $database = \Drupal::database();
  foreach ($schema as $table_name => $table_spec) {
    if (!$database->schema()->tableExists($table_name)) {
      $database->schema()->createTable($table_name, $table_spec);
    }
  }
}

/**
 * Implements hook_uninstall().
 */
function analyze_ai_sentiments_uninstall(): void {
  // Clean up any remaining data if tables exist.
  $database = \Drupal::database();
  $schema = $database->schema();

  if ($schema->tableExists('analyze_ai_sentiments_results')) {
    $database->delete('analyze_ai_sentiments_results')->execute();
  }
}

/**
 * Update plugin ID.
 *
 * Updates plugin ID from ai_sentiments_analyzer to
 * analyze_ai_sentiments_analyzer.
 */

/**
 * @return string
 */
function analyze_ai_sentiments_update_8001(): string {
  $config_factory = \Drupal::configFactory();
  $config = $config_factory->getEditable('analyze.settings');
  $status = $config->get('status') ?? [];
  $updated = FALSE;

  // Update plugin IDs in analyze.settings configuration.
  foreach ($status as $entity_type => $bundles) {
    foreach ($bundles as $bundle => $analyzers) {
      if (isset($analyzers['ai_sentiments_analyzer'])) {
        // Copy old setting to new plugin ID.
        $analyzers['analyze_ai_sentiments_analyzer'] = $analyzers['ai_sentiments_analyzer'];
        // Remove old plugin ID.
        unset($analyzers['ai_sentiments_analyzer']);
        // Update the configuration.
        $status[$entity_type][$bundle] = $analyzers;
        $updated = TRUE;
      }
    }
  }

  if ($updated) {
    $config->set('status', $status)->save();
    return t('Updated sentiments analyzer plugin ID from "ai_sentiments_analyzer" to "analyze_ai_sentiments_analyzer" in analyze settings.');
  }

  return t('No sentiments analyzer settings found to update.');
}
